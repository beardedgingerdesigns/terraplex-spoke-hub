{
  "fields": {
    "drones": {
      "label": "Drones carried",
      "allowedValues": ["r-32", "i-19"],
      "multiple": true,
      "required": true
    },
    "competitorDrones": {
      "label": "Other drone brands carried",
      "allowedValues": ["DJI", "XAG", "EAVision"],
      "multiple": true,
      "required": false,
      "note": "Acknowledged but not featured on dealer sites. Don't list specific non-GTEEX model names."
    },
    "additionalEquipment": {
      "label": "Additional equipment",
      "allowedValues": ["trailers", "skids", "drone cleaners", "software", "drift control agents"],
      "multiple": true,
      "required": false
    },
    "services": {
      "label": "Services offered",
      "allowedValues": [
        "Drone Sales",
        "Custom Spraying/Application",
        "Service & Repair",
        "Parts",
        "Training & Certification",
        "Regulatory Support",
        "Mapping & Data",
        "Consulting"
      ],
      "multiple": true,
      "required": true
    },
    "brandVibe": {
      "label": "Brand vibe",
      "allowedValues": [
        "Clean/Professional",
        "Bold/Edgy",
        "Farm-focused/Down-to-earth",
        "Modern/Tech-forward",
        "Patriotic",
        "Luxury/Premium"
      ],
      "multiple": false,
      "required": true,
      "note": "Used to guide archetype selection. See archetypes/_index.json `vibes` arrays for the mapping."
    },
    "formFields": {
      "label": "Contact form configuration",
      "required": true,
      "baseFields": ["name", "email", "phone", "message"],
      "commonExtraFields": [
        { "name": "interest", "label": "Interest dropdown (Drones/Service/Parts/Training)", "type": "select" },
        { "name": "acres", "label": "Acres farmed", "type": "number" },
        { "name": "crop", "label": "Primary crop", "type": "text" },
        { "name": "platform", "label": "Current drone platform", "type": "text" }
      ],
      "note": "Every form includes Name/Email/Phone/Message as base fields. During onboarding, ask whether the dealer qualifies leads (add Acres/Crop/Platform) or categorizes intent (add Interest dropdown). Pyro Ag uses Interest; Great River uses Acres/Crop/Platform; most other dealers use base only."
    }
  }
}
